{
  "kind": "collectionType",
  "collectionName": "faqs",
  "info": {
    "singularName": "faq",
    "pluralName": "faqs",
    "displayName": "FAQ",
    "description": "Frequently asked questions grouped by page section (homepage, accounts, services, payments, partnerships, social-trading)."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "question": {
      "type": "string",
      "required": true
    },
    "answer": {
      "type": "text",
      "required": true
    },
    "section": {
      "type": "enumeration",
      "enum": [
        "homepage",
        "accounts",
        "services",
        "payments",
        "partnerships",
        "social-trading"
      ],
      "required": true,
      "default": "homepage"
    },
    "order": {
      "type": "integer",
      "default": 0
    }
  }
}
