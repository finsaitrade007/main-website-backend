{
  "collectionName": "components_shared_seos",
  "info": {
    "displayName": "Seo",
    "description": "Per-page SEO metadata (title, description, keywords, social, structured data).",
    "icon": "search"
  },
  "options": {},
  "attributes": {
    "metaTitle": {
      "type": "string",
      "required": true,
      "maxLength": 60,
      "minLength": 5
    },
    "metaDescription": {
      "type": "text",
      "required": true,
      "maxLength": 160,
      "minLength": 50
    },
    "keywords": {
      "type": "text"
    },
    "metaRobots": {
      "type": "string",
      "default": "index, follow",
      "regex": "^[a-zA-Z, ]+$"
    },
    "canonicalURL": {
      "type": "string"
    },
    "metaViewport": {
      "type": "string",
      "default": "width=device-width, initial-scale=1"
    },
    "structuredData": {
      "type": "json"
    },
    "metaSocial": {
      "type": "component",
      "repeatable": true,
      "component": "shared.meta-social"
    }
  }
}
